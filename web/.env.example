# Supabase — credenciales públicas del cliente (no son secretas: la publishable
# key está pensada para ir en el bundle del front). Copia este archivo a
# .env.local y rellena con los valores de tu proyecto (Project Settings → API).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Google Maps (Street View). Clave restringida por referrer HTTP al dominio.
# Pública por diseño (va en el bundle del cliente).
VITE_GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
