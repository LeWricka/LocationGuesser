# Supabase — credenciales públicas del cliente (no son secretas: la publishable
# key está pensada para ir en el bundle del front). Copia este archivo a
# .env.local y rellena con los valores de tu proyecto (Project Settings → API).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Google Maps (Street View). Clave restringida por referrer HTTP al dominio.
# Pública por diseño (va en el bundle del cliente).
VITE_GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Mixpanel — token público de analítica (va en el bundle del cliente). Opcional:
# si se omite, la lib usa un fallback embebido. Vacíalo o usa VITE_ANALYTICS_DISABLED
# para desactivar la analítica en un entorno concreto.
VITE_MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pon a "true" para desactivar la analítica (no inicializa Mixpanel ni manda eventos).
# (También desactiva Sentry, abajo, con el mismo interruptor).
VITE_ANALYTICS_DISABLED=false

# Sentry — DSN público de captura de errores (va en el bundle del cliente, como
# la publishable key de Supabase). OPCIONAL: si se omite, la observabilidad queda
# desactivada (no-op) y la app arranca igual. También se desactiva en tests
# (MODE === 'test') o con VITE_ANALYTICS_DISABLED='true'.
# Pasos: crea un proyecto en Sentry (plataforma React) → copia el DSN (público) →
# ponlo en Vercel (env del front, sin re-deploy manual: el siguiente deploy lo
# coge) y en tu .env.local local.
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxx@oNNNNNN.ingest.sentry.io/NNNNNN

# ── E2E autenticados (#140) ───────────────────────────────────────────────────
# Credenciales del usuario de test para la suite E2E autenticada. Si NO están,
# la suite autenticada se SALTA y solo corre el smoke hermético (que no necesita
# login). El smoke pasa con o sin estas variables.
#
# El usuario se crea/confirma con `npm run e2e:seed-user` (ver más abajo). Luego,
# `npm run e2e` con estas dos definidas autentica por password y corre la suite:
E2E_USER_EMAIL=e2e@example.com
E2E_USER_PASSWORD=pon-una-password-larga-y-aleatoria

# Solo para `npm run e2e:seed-user` (crear/confirmar el usuario de test). La
# SERVICE ROLE KEY es SECRETA (omite RLS): NUNCA la commitees ni la dejes aquí en
# .env.local versionado. Pásala por el entorno o por secrets de CI al correr el seed:
#   SUPABASE_SERVICE_ROLE_KEY=... npm run e2e:seed-user
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
#
# En GitHub Actions (suite autenticada opcional): define como SECRETS del repo
#   E2E_USER_EMAIL, E2E_USER_PASSWORD, SUPABASE_SERVICE_ROLE_KEY
# (las VITE_SUPABASE_* públicas pueden ir como secrets o variables). El job del
# smoke en CI NO necesita ninguno de estos: corre `npx playwright test smoke`.
